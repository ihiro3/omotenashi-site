---
import Layout from '../layouts/PageLayout.astro';
import Hero from '../components/widgets/Hero.astro';
import Content from '../components/widgets/Content.astro';
import Steps from '../components/widgets/Steps.astro';
import { getPermalink } from '../utils/permalinks.ts';

const metadata = {
  title: 'About | OMOTENASHI - Miki Inoue',
};

const profileImage =
  'https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80';
const memberImage =
  'https://images.unsplash.com/photo-1528360983277-13d9b152c611?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80';
const heroImage =
  'https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80';
---

<Layout metadata={metadata}>
  {/* --- 1. プロフィール冒頭 --- */}
  <Hero
    tagline="About Me"
    image={{
      src: profileImage,
      alt: 'Miki Inoue - Travel Interpreter Guide',
    }}
  >
    <Fragment slot="title">
      Your Local Friend in<br />
      <span class="text-pink-600 dark:text-pink-400 highlight">Japan</span>
    </Fragment>

    <Fragment slot="subtitle">
      Dedicated personal guide and Travel Interpreter Guide, offering 100% custom private tours with authentic Japanese
      hospitality.
    </Fragment>
  </Hero>

  {/* --- 2. Services --- */}
  <Steps
    title="My Services"
    image={{
      src: memberImage,
      alt: 'Travel Guide Services',
    }}
    items={[
      {
        title: 'Custom Private Tours',
        description:
          '100% personalized tours tailored to your interests, schedule, and preferences. Experience Japan your way.',
        icon: 'tabler:map',
        callToAction: { text: 'Learn More', href: getPermalink('/#destinations') },
      },
      {
        title: 'Travel Interpretation',
        description:
          'Professional interpretation services to help you navigate language barriers and connect with local culture.',
        icon: 'tabler:language',
        callToAction: { text: 'Learn More', href: getPermalink('/#experiences') },
      },
      {
        title: 'Cultural Experiences',
        description: 'Authentic cultural activities including tea ceremonies, temple visits, and traditional arts.',
        icon: 'tabler:flower',
        callToAction: { text: 'Learn More', href: getPermalink('/#experiences') },
      },
      {
        title: 'Local Expertise',
        description: 'Insider knowledge of hidden gems, local restaurants, and off-the-beaten-path destinations.',
        icon: 'tabler:star',
        callToAction: { text: 'Learn More', href: getPermalink('/#about') },
      },
    ]}
  />

  {/* --- 3. Philosophy --- */}
  <Content
    isReversed
    title="OMOTENASHI Philosophy"
    subtitle="Japanese Hospitality at Its Finest"
    items={[
      {
        title: 'Personalized Experience',
        description:
          'Every tour is crafted specifically for you, ensuring your journey through Japan is unique and memorable.',
        icon: 'tabler:users',
      },
      {
        title: 'Authentic Connections',
        description: 'Experience Japan like a local, with genuine connections to culture, people, and traditions.',
        icon: 'tabler:heart',
      },
      {
        title: 'Warm Hospitality',
        description: 'OMOTENASHI spirit ensures you feel welcome, cared for, and at home throughout your journey.',
        icon: 'tabler:flower',
      },
    ]}
    image={{
      src: heroImage,
      alt: 'Japanese culture and hospitality',
    }}
  />
</Layout>
