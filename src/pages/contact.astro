---
import Layout from '../layouts/PageLayout.astro';
import ContactUs from '../components/widgets/Contact.astro';
import Hero from '../components/widgets/Hero.astro';
import Features2 from '../components/widgets/Features2.astro';

const metadata = {
  title: 'Contact | OMOTENASHI - Miki Inoue',
};

const heroImage =
  'https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1000&q=80';
---

<Layout metadata={metadata}>
  {/* 1. ページの見出し */}
  <Hero
    tagline="Contact"
    image={{
      src: heroImage,
      alt: 'Contact Miki Inoue',
    }}
  >
    <Fragment slot="title">
      Let's Plan Your<br />
      <span class="text-pink-600 dark:text-pink-400 highlight">Japanese Adventure</span>
    </Fragment>

    <Fragment slot="subtitle">
      Ready to explore Japan with a local friend? Get in touch to start planning your custom tour.
    </Fragment>
  </Hero>

  {/* 2. Contact Information */}
  <Features2
    title="Get in Touch"
    subtitle="I'm here to help you plan the perfect Japanese experience. Reach out through any of these channels."
    items={[
      {
        title: 'Email',
        description: 'contact@omotenashi-japan.com<br />For tour inquiries and bookings',
        icon: 'tabler:mail',
      },
      {
        title: 'Phone / WhatsApp',
        description: '+81-90-XXXX-XXXX<br />Available for urgent inquiries',
        icon: 'tabler:phone',
      },
      {
        title: 'Response Time',
        description: 'Usually within 24 hours<br />Tours available 7 days a week',
        icon: 'tabler:clock',
      },
    ]}
  />

  {/* 3. メッセージ送信フォーム */}
  <ContactUs
    id="form"
    title="Send Me a Message"
    subtitle="Tell me about your dream Japan experience and I'll help make it happen."
    inputs={[
      {
        type: 'text',
        name: 'name',
        label: 'Your Name',
      },
      {
        type: 'email',
        name: 'email',
        label: 'Email Address',
      },
    ]}
    textarea={{
      label: 'Tell me about your travel plans, interests, and any questions you have.',
    }}
    disclaimer={{
      label: 'Your personal information will only be used to respond to your inquiry.',
    }}
    button="Send Message"
  />

  {/* 補足：フォームの動作について */}
  <div class="max-w-3xl mx-auto text-center pb-24 px-4">
    <p class="text-sm text-gray-500">
      I typically respond within 24 hours. Let's start planning your Japanese adventure!
    </p>
  </div>
</Layout>
