---
import CallToAction from '../components/widgets/CallToAction.astro';
import Content from '../components/widgets/Content.astro';
import Features2 from '../components/widgets/Features2.astro';
import Hero from '../components/widgets/Hero.astro';
import Testimonials from '../components/widgets/Testimonials.astro';
import Layout from '../layouts/PageLayout.astro';

const metadata = {
  title: 'Services | OMOTENASHI - Miki Inoue',
};

const heroImage =
  'https://images.unsplash.com/photo-1493976040374-85c8e12f0c0e?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80';
const featuresImage =
  'https://images.unsplash.com/photo-1524413840807-0c3cb6fa808d?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80';
const benefitsImage =
  'https://images.unsplash.com/photo-1492571350019-22de08371fd3?ixlib=rb-4.0.3&auto=format&fit=crop&w=774&q=80';
const testimonialImageEmily =
  'https://images.unsplash.com/photo-1618835962148-cf177563c6c0?ixlib=rb-4.0.3&auto=format&fit=crop&w=930&q=80';
const testimonialImageSarah =
  'https://images.unsplash.com/photo-1561406636-b80293969660?ixlib=rb-4.0.3&auto=format&fit=crop&w=774&q=80';
const testimonialImageMark =
  'https://images.unsplash.com/photo-1545167622-3a6ac756afa4?ixlib=rb-4.0.3&auto=format&fit=crop&w=824&q=80';
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->

  <Hero
    tagline="Services"
    title="Discover Japan Your Way"
    subtitle="Experience authentic Japan through personalized guided tours. From cultural immersion to hidden local gems, I craft custom experiences tailored to your interests and schedule."
    actions={[{ variant: 'primary', target: '_self', text: 'Contact Me', href: '/contact' }]}
    image={{
      src: heroImage,
      alt: 'Japan travel experience',
    }}
  />

  <!-- Features2 Widget ************** -->

  <Features2
    title="Tour Services"
    subtitle="Choose from my range of personalized travel experiences."
    columns={3}
    items={[
      {
        title: 'Custom Private Tours',
        description:
          'Tailor-made itineraries designed around your interests, pace, and preferences. Experience Japan exactly how you want to.',
        icon: 'tabler:map',
      },
      {
        title: 'Cultural Experiences',
        description:
          'Deep dive into Japanese culture with tea ceremonies, temple visits, traditional arts, and authentic local activities.',
        icon: 'tabler:flower',
      },
      {
        title: 'Travel Interpretation',
        description:
          'Professional interpretation services to help you communicate with locals and navigate language barriers with ease.',
        icon: 'tabler:language',
      },
      {
        title: 'Day Tours',
        description:
          'Perfect day trips from Tokyo, Kyoto, Osaka, and Hiroshima. Explore iconic landmarks and hidden gems in a single day.',
        icon: 'tabler:sun',
      },
      {
        title: 'Multi-Day Tours',
        description:
          'Comprehensive multi-city itineraries covering multiple destinations. Let me handle all the logistics while you enjoy.',
        icon: 'tabler:calendar',
      },
      {
        title: 'Special Experiences',
        description:
          'Seasonal festivals, cherry blossom viewing, autumn foliage, and other unique Japanese experiences timed perfectly.',
        icon: 'tabler:star',
      },
      {
        title: '🍣 Food Tours',
        description:
          'Discover Japan incredible culinary scene from street food to fine dining. Local restaurants and hidden food gems.',
      },
      {
        title: 'Photography Tours',
        description:
          'Capture stunning images of Japan most photogenic spots with guidance on the best locations and timing.',
        icon: 'tabler:camera',
      },
      {
        title: 'Family Tours',
        description:
          'Family-friendly itineraries with activities for all ages. Educational, fun, and memorable experiences for everyone.',
        icon: 'tabler:users',
      },
    ]}
  />

  <!-- Content Widget **************** -->

  <Content
    isReversed
    items={[
      {
        title: 'Local Expertise',
        description:
          'As a certified Travel Interpreter Guide, I bring deep knowledge of Japanese culture, history, and hidden local spots that most tourists never discover.',
        icon: 'tabler:map-star',
      },
      {
        title: 'Personalized Planning',
        description:
          'Every detail is tailored to you - from accommodation preferences to dietary needs, activity levels, and cultural interests.',
        icon: 'tabler:settings',
      },
      {
        title: 'Hassle-Free Experience',
        description:
          'I handle all logistics including transportation, reservations, and navigation so you can focus on enjoying your journey.',
        icon: 'tabler:checklist',
      },
      {
        title: 'Authentic Connections',
        description:
          'Experience genuine Japanese hospitality and connect with local people, traditions, and culture in meaningful ways.',
        icon: 'tabler:heart-handshake',
      },
    ]}
    image={{
      src: featuresImage,
      alt: 'Japanese cultural experience',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Why Choose Me</h3>
    </Fragment>
  </Content>

  <!-- Content Widget **************** -->

  <Content
    isAfterContent
    items={[
      {
        title: 'Save Time',
        description:
          'Skip the research and planning headaches. I handle everything so you can maximize your time experiencing Japan.',
        icon: 'tabler:clock',
      },
      {
        title: 'Local Insights',
        description:
          'Access knowledge that guidebooks don have - secret spots, best times to visit, and local recommendations from a resident expert.',
        icon: 'tabler:bulb',
      },
      {
        title: 'Stress-Free Travel',
        description:
          'Navigate Japan with confidence. No language barriers, no getting lost, no missed connections - just smooth, enjoyable travel.',
        icon: 'tabler:shield-check',
      },
      {
        title: 'Flexible Scheduling',
        description:
          'Tours available 7 days a week with flexible timing. Early morning starts or late evening explorations - whatever suits you.',
        icon: 'tabler:calendar-time',
      },
    ]}
    image={{
      src: benefitsImage,
      alt: 'Stress-free Japan travel',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Tour Benefits</h3>
    </Fragment>
  </Content>

  <!-- Testimonials Widget *********** -->

  <Testimonials
    title="What My Guests Say"
    testimonials={[
      {
        testimonial: `Miki made our Japan trip absolutely incredible. Her local knowledge took us to places we never would have found on our own. The tea ceremony experience was unforgettable!`,
        name: 'Emily Kennedy',
        job: 'Traveler from USA',
        image: {
          src: testimonialImageEmily,
          alt: 'Emily Kennedy Image',
        },
      },
      {
        testimonial: `As a solo female traveler, I felt completely safe and well-cared for. Miki's interpretation skills were invaluable, and she introduced me to authentic Japanese culture I couldn't have experienced otherwise.`,
        name: 'Sarah Hansen',
        job: 'Traveler from Australia',
        image: {
          src: testimonialImageSarah,
          alt: 'Sarah Hansen Image',
        },
      },
      {
        testimonial: `Our family tour with Miki was perfect. She balanced activities for all ages and even accommodated my dietary restrictions. The kids still talk about the cherry blossom viewing!`,
        name: 'Mark Wilkinson',
        job: 'Family traveler from UK',
        image: {
          src: testimonialImageMark,
          alt: 'Mark Wilkinson Image',
        },
      },
    ]}
    callToAction={{
      target: '_self',
      text: 'Contact me to plan your tour',
      href: '/contact',
      icon: 'tabler:chevron-right',
    }}
  />

  <!-- CallToAction Widget *********** -->

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Start Your Journey',
        href: '/contact',
      },
    ]}
    title="Ready to Experience Authentic Japan?"
    subtitle="Let's create your perfect custom tour together. Contact me to start planning your Japanese adventure."
  />
</Layout>
