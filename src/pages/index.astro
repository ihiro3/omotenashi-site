---
import Layout from '../layouts/PageLayout.astro';

const metadata = {
  title: 'せいか自然観察倶楽部',
  ignoreTitleTemplate: true,
  description: '学研都市の豊かな自然を舞台に、子どもたちに自然観察や科学体験の機会を提供するせいか自然観察倶楽部。',
};

import equipmentImage from '../assets/images/476233573_1117206420098352_4014970075211524232_n.jpg';
import greetingImage from '../assets/images/yamashita-yoshikazu.png';
import eventsData from '../data/events.json';
import { findImage } from '../utils/images.ts';

// Resolve eyecatch image URLs and compute isOpen
const events = await Promise.all(
  eventsData.map(async (ev) => {
    const eyecatchImages = Array.isArray(ev.eyecatch) ? ev.eyecatch : [ev.eyecatch];
    const resolvedEyecatches = await Promise.all(
      eyecatchImages.map(async (imgPath) => {
        const loaded = await findImage(imgPath);
        return typeof loaded === 'string' ? loaded : (loaded?.src ?? imgPath);
      })
    );
    const deadline = ev.registrationDeadline ? new Date(ev.registrationDeadline) : null;
    const isOpen = ev.status === 'open' || (ev.status !== 'closed' && deadline ? new Date() < deadline : false);
    // Prepare application href (Google Form or mailto)
    const applyHref = isOpen
      ? ev.googleFormUrl
        ? ev.googleFormUrl.replace('{{EVENT}}', encodeURIComponent(ev.title))
        : `mailto:${ev.applyEmail}?subject=${encodeURIComponent(ev.title + ' 申し込み')}&body=${encodeURIComponent(`【${ev.title} 申し込み】\n・お子様のお名前：\n・学校名・学年・性別： 小学校 年 男・女\n・保護者のお名前：\n・郵便番号：\n・住所：\n・電話番号：\n・希望コース： A・B\n・第二希望を： 希望する・希望しない`)}`
      : undefined;

    return { ...ev, eyecatch: resolvedEyecatches[0], eyecatches: resolvedEyecatches, isOpen, applyHref };
  })
);
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <section id="home" class="relative scroll-mt-32 pt-36 pb-16 sm:pt-40 sm:pb-20 lg:pt-44 lg:pb-24">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-green-600 font-semibold mb-4">せいか自然観察倶楽部</p>
          <h1
            class="text-4xl sm:text-5xl md:text-5xl lg:text-5xl xl:text-5xl font-bold text-gray-900 dark:text-white mb-6 leading-tight"
          >
            人・自然・科学を結ぶサイエンス体験
          </h1>
          <p class="text-base sm:text-lg text-gray-700 dark:text-slate-300 mb-8 leading-relaxed max-w-2xl">
            子どもたちに自然観察・科学体験・理科工作等の機会を提供し、豊かな感性と確かな科学の知識・技能を育むプログラムを実施しています。
          </p>
        </div>
        <div class="relative">
          <img
            src={equipmentImage?.src ?? equipmentImage}
            alt="科学体験機材"
            class="rounded-2xl shadow-2xl w-full h-auto"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Upcoming Event Section -->
  <section id="event" class="relative scroll-mt-24 py-16 sm:py-24 bg-gray-50 dark:bg-slate-800">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl mb-4">
          直近の開催予定イベント
        </h2>
        <p class="text-lg text-gray-600 dark:text-slate-300">地上望遠鏡作りと理科工作</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start mb-12">
        <div class="space-y-6">
          {/* Render events from data file */}
          {
            events.map((ev) => (
              <div class="bg-white dark:bg-slate-700 rounded-2xl shadow-lg overflow-hidden">
                <div class="grid gap-4 md:grid-cols-2">
                  {ev.eyecatches.map((src) => (
                    <a
                      href={src}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="block overflow-hidden rounded-2xl shadow-sm bg-white dark:bg-slate-600 transition hover:scale-[1.01] hover:shadow-lg"
                    >
                      <img src={src} alt={ev.title} class="w-full h-auto" />
                    </a>
                  ))}
                </div>
                <div class="p-6">
                  <div class="flex items-start justify-between gap-4">
                    <div>
                      <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">{ev.title}</h3>
                      <p class="text-sm text-gray-600 dark:text-slate-300">
                        {ev.location}
                        {ev.courses && ev.courses.length > 0 ? (
                          <span>
                            ・
                            {ev.courses
                              .map(
                                (c) =>
                                  `${c.name}: ${new Date(c.date).toLocaleDateString('ja-JP')} ${new Date(c.date).toLocaleTimeString('ja-JP', { hour: '2-digit', minute: '2-digit' })}-${new Date(c.endTime).toLocaleTimeString('ja-JP', { hour: '2-digit', minute: '2-digit' })}`
                              )
                              .join('、')}
                          </span>
                        ) : (
                          <span>・{new Date(ev.date).toLocaleDateString('ja-JP')}</span>
                        )}
                      </p>
                    </div>
                    <div class="text-right">
                      <span
                        class={
                          ev.isOpen
                            ? 'inline-flex items-center px-3 py-1 rounded-full text-sm bg-green-100 dark:bg-green-900 text-green-800 dark:text-green-200'
                            : 'inline-flex items-center px-3 py-1 rounded-full text-sm bg-gray-200 dark:bg-slate-600 text-gray-600 dark:text-slate-300'
                        }
                      >
                        {ev.isOpen ? '募集中' : '募集終了'}
                      </span>
                    </div>
                  </div>

                  <div class="mt-4">
                    <a
                      href={ev.applyHref}
                      class={
                        ev.isOpen
                          ? 'inline-flex items-center justify-center w-full px-6 py-3 text-sm font-semibold text-white bg-green-600 rounded-lg hover:bg-green-700'
                          : 'inline-flex items-center justify-center w-full px-6 py-3 text-sm font-semibold text-gray-700 dark:text-slate-300 bg-gray-200 dark:bg-slate-600 rounded-lg cursor-not-allowed'
                      }
                      aria-disabled={!ev.isOpen}
                      title={
                        !ev.isOpen ? '募集は終了しています' : ev.googleFormUrl ? 'Googleフォームで応募' : 'メールで応募'
                      }
                    >
                      応募する
                    </a>
                  </div>
                </div>
              </div>
            ))
          }
        </div>

        <div class="bg-white dark:bg-slate-700 rounded-2xl shadow-lg p-8 sm:p-12">
          <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">イベントへの応募方法</h3>
          <p class="text-gray-600 dark:text-slate-300 mb-6">
            各イベントの「応募する」ボタンからGoogleフォームにアクセスできます。Googleフォームが使えない場合はメール、FAXや郵送でも受け付けます。
          </p>
          <div class="mt-8 pt-8 border-t border-gray-200 dark:border-slate-600">
            <p class="text-sm text-gray-500 dark:text-slate-400 mb-2">Googleフォームを使わない方向け</p>
            <p class="text-base text-gray-700 dark:text-slate-300">
              メール、FAXや郵送での応募も受け付けています。詳細はイベントチラシをご確認ください。
            </p>
          </div>
          <div class="mt-8 bg-gray-50 dark:bg-slate-600 rounded-lg p-6">
            <h4 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">メールで応募する場合</h4>
            <p class="text-sm text-gray-700 dark:text-slate-300 mb-4">
              以下の内容を記載して、イベントチラシに記載のメールアドレスまでお送りください。
            </p>
            <pre
              class="text-sm text-gray-700 dark:text-slate-300 whitespace-pre-wrap font-sans">【イベント申し込み】
・プログラム名：
・お子様のお名前：
・学校名・学年・性別： 小学校 年 男・女
・保護者のお名前：
・郵便番号：
・住所：
・電話番号：
・希望コース： A・B
・第二希望を： 希望する・希望しない
            </pre>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Program Highlights Section -->
  <section id="programs" class="relative scroll-mt-24 py-16 sm:py-24 bg-white dark:bg-slate-800">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl mb-4">プログラム紹介</h2>
        <p class="text-lg text-gray-600 dark:text-slate-300">
          自然を観察し、科学を体験する3つの柱で、子どもたちの好奇心を育てます。
        </p>
      </div>

      <div class="grid gap-8 lg:grid-cols-3">
        <div
          class="rounded-3xl border border-gray-200 dark:border-slate-600 bg-gray-50 dark:bg-slate-700 p-8 shadow-sm"
        >
          <div
            class="inline-flex items-center justify-center h-14 w-14 rounded-full bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-200 mb-6"
          >
            🌿
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">自然観察</h3>
          <p class="text-gray-600 dark:text-slate-300 leading-relaxed">
            学研都市の緑豊かな里山や水辺を歩き、季節ごとの生きものや植物の変化を観察します。
          </p>
        </div>

        <div
          class="rounded-3xl border border-gray-200 dark:border-slate-600 bg-gray-50 dark:bg-slate-700 p-8 shadow-sm"
        >
          <div
            class="inline-flex items-center justify-center h-14 w-14 rounded-full bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-200 mb-6"
          >
            🔬
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">科学体験</h3>
          <p class="text-gray-600 dark:text-slate-300 leading-relaxed">
            実験や工作を通じて、科学の仕組みを楽しく学び、理科への興味を深めます。
          </p>
        </div>

        <div
          class="rounded-3xl border border-gray-200 dark:border-slate-600 bg-gray-50 dark:bg-slate-700 p-8 shadow-sm"
        >
          <div
            class="inline-flex items-center justify-center h-14 w-14 rounded-full bg-green-100 dark:bg-green-900 text-green-700 dark:text-green-200 mb-6"
          >
            🧩
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">理科工作</h3>
          <p class="text-gray-600 dark:text-slate-300 leading-relaxed">
            身近な素材を使った工作で、観察したことを形にしながら考える力を育てます。
          </p>
        </div>
      </div>

      <div class="mt-12 text-center">
        <a
          href="/#event"
          class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white bg-green-600 rounded-xl shadow-md hover:bg-green-700 transition-colors"
        >
          お問い合わせ・参加申し込み
        </a>
      </div>
    </div>
  </section>

  <!-- Representative Greeting Section -->
  <section id="greeting" class="relative scroll-mt-24 py-16 sm:py-24">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl mb-4">代表挨拶</h2>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div class="bg-white rounded-2xl shadow-lg p-8 sm:p-12">
          <div class="prose max-w-none">
            <p class="text-gray-900 whitespace-pre-wrap leading-relaxed">
              本倶楽部は、学研都市及び近隣の子どもたちに「自然観察・科学体験・理科工作等」の機会を提供して、「感性豊かな人間」の育成に寄与すると共に、子どもたちに「しっかりとした理科（科学）の知識と技能」を身に付けてもらうことを大きな目的としています。そして活動を通して、近隣の豊かで多様な自然や文化に気づき、自然を愛する心や豊かな感性等が育つことを願っています。
              また、学研都市の「強み」を生かして「人・自然・科学を結ぶ
              "せいか自然観察倶楽部"」をテーマのひとつに掲げて、人と人・人と自然・人と科学・自然と科学を結び付け、学校教育ではできない体験や研究所の実証実験に参加したり等しながら、「自然観察・科学体験・理科工作等」を基盤に幅広いサイエンス活動を目指していくものです。
              活動趣旨に御理解を賜り、多くの皆様方の御協力と御支援のもと、本倶楽部がより良く活動出来ますことを願っています。
              せいか自然観察倶楽部 代表 山下 芳一
            </p>
          </div>
        </div>
        <div class="bg-white rounded-2xl shadow-lg overflow-hidden">
          <img
            src={greetingImage?.src ?? greetingImage}
            alt="せいか自然観察倶楽部の活動風景"
            class="w-3/5 h-auto mx-auto"
          />
        </div>
      </div>
    </div>
  </section>
</Layout>
