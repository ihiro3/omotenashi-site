---
import Layout from '../layouts/PageLayout.astro';

const metadata = {
  title: 'OMOTENASHI - Miki Inoue | Travel Interpreter Guide',
  ignoreTitleTemplate: true,
  description:
    'Dedicated personal guide and Travel Interpreter Guide. 100% custom private tours with a local friend. Explore Tokyo, Kyoto, Osaka, Hiroshima & more.',
};
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <section
    id="home"
    class="relative scroll-mt-32 pt-20 pb-12 sm:pt-24 sm:pb-16 lg:pt-20 lg:pb-20 bg-gradient-to-br from-pink-50 to-pink-100 dark:from-pink-950 dark:to-pink-900"
  >
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div>
          <p class="text-pink-600 dark:text-pink-400 font-semibold mb-4">OMOTENASHI おもてなし</p>
          <h1
            class="text-4xl sm:text-5xl md:text-5xl lg:text-5xl xl:text-5xl font-bold text-gray-900 dark:text-white mb-6 leading-tight"
          >
            Explore Japan's Wonders
          </h1>
          <p class="text-2xl sm:text-3xl font-semibold text-pink-700 dark:text-pink-300 mb-4">Miki Inoue</p>
          <p class="text-base sm:text-lg text-gray-700 dark:text-slate-300 mb-4 leading-relaxed max-w-2xl">
            Dedicated Personal Guide • Travel Interpreter Guide
          </p>
          <p class="text-base sm:text-lg text-gray-700 dark:text-slate-300 mb-8 leading-relaxed max-w-2xl">
            100% custom private tours with a local friend. Experience authentic Japan through personalized guidance.
          </p>
          <a
            href="#contact"
            class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white bg-pink-600 rounded-xl shadow-md hover:bg-pink-700 transition-colors"
          >
            Start Your Journey
          </a>
        </div>
        <div class="relative">
          <div
            class="bg-white dark:bg-slate-800 rounded-2xl shadow-2xl p-8 border-4 border-pink-200 dark:border-pink-700"
          >
            <div class="text-center">
              <img
                src="https://images.unsplash.com/photo-1592499494890-da4507c0c7d8?crop=entropy&cs=tinysrgb&fit=max&fm=jpg&ixid=M3wxMjA3fDB8MXxzZWFyY2h8Mnx8dG9reW8lMjBza3l0cmVlfGVufDB8fHx8MTc4MzgzODg2N3ww&ixlib=rb-4.1.0&q=80&w=1080"
                alt="Tokyo Skytree"
                class="w-full h-auto rounded-2xl shadow-lg mx-auto mb-4 object-cover"
              />
              <p class="text-gray-600 dark:text-slate-300 mb-4">Your gateway to Japanese culture</p>
              <div class="flex justify-center gap-2 flex-wrap">
                <span
                  class="px-3 py-1 bg-pink-100 dark:bg-pink-900 text-pink-800 dark:text-pink-200 rounded-full text-sm"
                  >Tokyo</span
                >
                <span
                  class="px-3 py-1 bg-pink-100 dark:bg-pink-900 text-pink-800 dark:text-pink-200 rounded-full text-sm"
                  >Kyoto</span
                >
                <span
                  class="px-3 py-1 bg-pink-100 dark:bg-pink-900 text-pink-800 dark:text-pink-200 rounded-full text-sm"
                  >Osaka</span
                >
                <span
                  class="px-3 py-1 bg-pink-100 dark:bg-pink-900 text-pink-800 dark:text-pink-200 rounded-full text-sm"
                  >Hiroshima</span
                >
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Destinations Section -->
  <section id="destinations" class="relative scroll-mt-24 py-12 sm:py-16 bg-white dark:bg-slate-800">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl mb-4">
          Explore Japan's Destinations
        </h2>
        <p class="text-lg text-gray-600 dark:text-slate-300">
          Discover the beauty and culture of Japan's most iconic cities
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        <div
          class="bg-gradient-to-br from-pink-50 to-pink-100 dark:from-pink-950 dark:to-pink-900 rounded-2xl shadow-lg p-6 border-2 border-pink-200 dark:border-pink-700 hover:shadow-xl transition-shadow"
        >
          <div class="text-4xl mb-4">🗼</div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Tokyo</h3>
          <p class="text-gray-600 dark:text-slate-300 text-sm">Modern meets traditional in Japan's vibrant capital</p>
        </div>

        <div
          class="bg-gradient-to-br from-pink-50 to-pink-100 dark:from-pink-950 dark:to-pink-900 rounded-2xl shadow-lg p-6 border-2 border-pink-200 dark:border-pink-700 hover:shadow-xl transition-shadow"
        >
          <div class="text-4xl mb-4">⛩️</div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Kyoto</h3>
          <p class="text-gray-600 dark:text-slate-300 text-sm">Ancient temples and timeless Japanese culture</p>
        </div>

        <div
          class="bg-gradient-to-br from-pink-50 to-pink-100 dark:from-pink-950 dark:to-pink-900 rounded-2xl shadow-lg p-6 border-2 border-pink-200 dark:border-pink-700 hover:shadow-xl transition-shadow"
        >
          <div class="text-4xl mb-4">🍜</div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Osaka</h3>
          <p class="text-gray-600 dark:text-slate-300 text-sm">Food paradise and energetic street culture</p>
        </div>

        <div
          class="bg-gradient-to-br from-pink-50 to-pink-100 dark:from-pink-950 dark:to-pink-900 rounded-2xl shadow-lg p-6 border-2 border-pink-200 dark:border-pink-700 hover:shadow-xl transition-shadow"
        >
          <div class="text-4xl mb-4">🕊️</div>
          <h3 class="text-xl font-bold text-gray-900 dark:text-white mb-2">Hiroshima</h3>
          <p class="text-gray-600 dark:text-slate-300 text-sm">History, peace, and the beautiful Miyajima</p>
        </div>
      </div>

      <div class="mt-12 text-center">
        <p class="text-gray-600 dark:text-slate-300 mb-4">And many more destinations across Japan</p>
        <a
          href="#contact"
          class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-white bg-pink-600 rounded-xl shadow-md hover:bg-pink-700 transition-colors"
        >
          Plan Your Custom Tour
        </a>
      </div>
    </div>
  </section>

  <!-- Experiences Section -->
  <section
    id="experiences"
    class="relative scroll-mt-24 py-16 sm:py-24 bg-gradient-to-br from-pink-50 to-pink-100 dark:from-pink-950 dark:to-pink-900"
  >
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-7xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl mb-4">
          Unique Japanese Experiences
        </h2>
        <p class="text-lg text-gray-600 dark:text-slate-300">
          Create unforgettable memories with authentic Japanese activities
        </p>
      </div>

      <div class="grid gap-8 lg:grid-cols-3">
        <div class="rounded-3xl border-2 border-pink-200 dark:border-pink-700 bg-white dark:bg-slate-800 p-8 shadow-lg">
          <div
            class="inline-flex items-center justify-center h-14 w-14 rounded-full bg-pink-100 dark:bg-pink-900 text-pink-700 dark:text-pink-200 mb-6"
          >
            🚄
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Bullet Train</h3>
          <p class="text-gray-600 dark:text-slate-300 leading-relaxed">
            Experience the world-famous Shinkansen bullet train, traveling between cities at speeds up to 320 km/h.
          </p>
        </div>

        <div class="rounded-3xl border-2 border-pink-200 dark:border-pink-700 bg-white dark:bg-slate-800 p-8 shadow-lg">
          <div
            class="inline-flex items-center justify-center h-14 w-14 rounded-full bg-pink-100 dark:bg-pink-900 text-pink-700 dark:text-pink-200 mb-6"
          >
            ⛩️
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Temples & Shrines</h3>
          <p class="text-gray-600 dark:text-slate-300 leading-relaxed">
            Visit ancient temples and shrines, learning about Japanese spirituality, architecture, and traditions.
          </p>
        </div>

        <div class="rounded-3xl border-2 border-pink-200 dark:border-pink-700 bg-white dark:bg-slate-800 p-8 shadow-lg">
          <div
            class="inline-flex items-center justify-center h-14 w-14 rounded-full bg-pink-100 dark:bg-pink-900 text-pink-700 dark:text-pink-200 mb-6"
          >
            🚣
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Boating</h3>
          <p class="text-gray-600 dark:text-slate-300 leading-relaxed">
            Enjoy peaceful boat rides through scenic rivers, lakes, and traditional Japanese gardens.
          </p>
        </div>

        <div class="rounded-3xl border-2 border-pink-200 dark:border-pink-700 bg-white dark:bg-slate-800 p-8 shadow-lg">
          <div
            class="inline-flex items-center justify-center h-14 w-14 rounded-full bg-pink-100 dark:bg-pink-900 text-pink-700 dark:text-pink-200 mb-6"
          >
            🛍️
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Shopping</h3>
          <p class="text-gray-600 dark:text-slate-300 leading-relaxed">
            From traditional crafts to modern fashion, discover unique shopping districts and local markets.
          </p>
        </div>

        <div class="rounded-3xl border-2 border-pink-200 dark:border-pink-700 bg-white dark:bg-slate-800 p-8 shadow-lg">
          <div
            class="inline-flex items-center justify-center h-14 w-14 rounded-full bg-pink-100 dark:bg-pink-900 text-pink-700 dark:text-pink-200 mb-6"
          >
            🎎
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Cultural Experiences</h3>
          <p class="text-gray-600 dark:text-slate-300 leading-relaxed">
            Participate in tea ceremonies, calligraphy, kimono wearing, and other traditional Japanese arts.
          </p>
        </div>

        <div class="rounded-3xl border-2 border-pink-200 dark:border-pink-700 bg-white dark:bg-slate-800 p-8 shadow-lg">
          <div
            class="inline-flex items-center justify-center h-14 w-14 rounded-full bg-pink-100 dark:bg-pink-900 text-pink-700 dark:text-pink-200 mb-6"
          >
            ✨
          </div>
          <h3 class="text-xl font-semibold text-gray-900 dark:text-white mb-3">Unique Experiences</h3>
          <p class="text-gray-600 dark:text-slate-300 leading-relaxed">
            Custom activities tailored to your interests - from seasonal festivals to hidden local gems.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- About Section -->
  <section id="about" class="relative scroll-mt-24 py-12 sm:py-16 bg-white dark:bg-slate-800">
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-6xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-4xl mb-4">
          Your Local Friend in Japan
        </h2>
        <p class="text-lg text-gray-600 dark:text-slate-300">
          Experience Japan like a local with personalized guidance
        </p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
        <div
          class="bg-gradient-to-br from-pink-50 to-pink-100 dark:from-pink-950 dark:to-pink-900 rounded-2xl shadow-lg p-8 sm:p-12 border-2 border-pink-200 dark:border-pink-700"
        >
          <div class="prose max-w-none">
            <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-6">100% Custom Private Tours</h3>
            <p class="text-gray-700 dark:text-slate-300 leading-relaxed mb-4">
              As your dedicated personal guide and Travel Interpreter Guide, I offer completely customized private tours
              tailored to your interests, schedule, and preferences.
            </p>
            <p class="text-gray-700 dark:text-slate-300 leading-relaxed mb-4">
              Unlike group tours, you'll experience Japan as if traveling with a local friend. I'll help you discover
              hidden gems, navigate language barriers, and create authentic connections with Japanese culture.
            </p>
            <p class="text-gray-700 dark:text-slate-300 leading-relaxed mb-4">
              From the bustling streets of Tokyo to the serene temples of Kyoto, from the food paradise of Osaka to the
              historic beauty of Hiroshima - I'll craft your perfect Japanese adventure.
            </p>
            <div class="mt-6 p-4 bg-white dark:bg-slate-800 rounded-lg">
              <p class="text-pink-700 dark:text-pink-300 font-semibold mb-2">OMOTENASHI おもてなし</p>
              <p class="text-gray-600 dark:text-slate-300 text-sm">
                Japanese hospitality at its finest - I'll ensure your journey through Japan is warm, welcoming, and
                unforgettable.
              </p>
            </div>
          </div>
        </div>
        <div
          class="bg-white dark:bg-slate-800 rounded-2xl shadow-lg overflow-hidden border-2 border-pink-200 dark:border-pink-700"
        >
          <div class="p-8 text-center">
            <div class="text-8xl mb-6">🌸</div>
            <h3 class="text-2xl font-bold text-gray-900 dark:text-white mb-4">Miki Inoue</h3>
            <p class="text-pink-600 dark:text-pink-400 font-semibold mb-4">Travel Interpreter Guide</p>
            <p class="text-gray-600 dark:text-slate-300 mb-6">
              Certified guide passionate about sharing Japan's rich culture, history, and hidden treasures with visitors
              from around the world.
            </p>
            <a
              href="#contact"
              class="inline-flex items-center justify-center px-6 py-3 text-base font-semibold text-white bg-pink-600 rounded-lg hover:bg-pink-700 transition-colors"
            >
              Get in Touch
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact CTA Section -->
  <section
    id="contact"
    class="relative scroll-mt-24 py-16 sm:py-24 bg-gradient-to-br from-pink-600 to-pink-700 dark:from-pink-800 dark:to-pink-900"
  >
    <div class="mx-auto px-4 sm:px-6 lg:px-8 max-w-4xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl mb-4">Ready to Explore Japan?</h2>
      <p class="text-lg text-pink-100 mb-8">
        Let's create your perfect custom tour together. Contact me to start planning your Japanese adventure.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-pink-700 bg-white rounded-xl shadow-md hover:bg-pink-50 transition-colors"
      >
        Contact Miki Inoue
      </a>
    </div>
  </section>
</Layout>
